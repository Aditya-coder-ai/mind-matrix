{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "auth": {
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "ThinkSphere",
        "supportEmail": "jha.adi033@gmail.com",
        "authorizedRedirectUris": [
          "http://localhost",
          "https://thinksphere-e744c.firebaseapp.com",
          "https://thinksphere-e744c.web.app"
        ]
      }
    }
  }
}
